{
  "name": "blog-nextjs",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/copy-content-images.js",
    "build": "next build --webpack && next-sitemap",
    "prebuild": "node scripts/copy-content-images.js",
    "postbuild": "next-sitemap",
    "start": "next start",
    "format": "oxfmt --check 'src/**/*.{js,jsx,ts,tsx,scss}' '**/*.json' 'CLAUDE.md'",
    "format:write": "oxfmt 'src/**/*.{js,jsx,ts,tsx,scss}' '**/*.json' 'CLAUDE.md'",
    "lint": "oxlint --config .oxlintrc.json src",
    "lint:fix": "oxlint --config .oxlintrc.json --fix src",
    "type-check": "tsgo --noEmit",
    "type-check:tsc": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "gray-matter": "^4.0.3",
    "next": "^16.2.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-prism-plus": "^2.0.2",
    "rehype-raw": "^7.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "serwist": "^9.5.7",
    "strip-markdown": "^6.0.0"
  },
  "devDependencies": {
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next-sitemap": "^4.2.3",
    "oxfmt": "0.46.0",
    "oxlint": "1.60.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix --config .oxlintrc.json",
      "oxfmt"
    ],
    "*.scss": [
      "oxfmt"
    ],
    "*.json": [
      "oxfmt"
    ],
    "CLAUDE.md": [
      "oxfmt"
    ]
  }
}
