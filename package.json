{
  "name": "blog-nextjs",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/copy-content-images.js",
    "build": "next build && next-sitemap",
    "prebuild": "node scripts/copy-content-images.js",
    "postbuild": "next-sitemap",
    "start": "next start",
    "format": "prettier --check 'src/**/*.{js,jsx,ts,tsx}'",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "migrate:contentful": "node --env-file=.env.local --import tsx scripts/migrate-contentful/index.ts"
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "^16.1.6",
    "contentful": "^11.9.0",
    "gray-matter": "^4.0.3",
    "next": "^15.4.8",
    "next-pwa": "^5.6.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "rehype-prism-plus": "^2.0.2",
    "rehype-raw": "^7.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "sass": "^1.83.1",
    "strip-markdown": "^6.0.0"
  },
  "devDependencies": {
    "@types/gtag.js": "^0.0.20",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "mime-types": "^3.0.2",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
